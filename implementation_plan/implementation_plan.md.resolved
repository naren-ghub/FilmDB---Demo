"ENTITY_LOOKUP":  {"required": ["kb_entity"], "optional": ["imdb", "wikipedia", "watchmode"], ...},
"TOP_RATED":      {"required": ["kb_top_rated"], "optional": ["imdb_top_rated_english"], ...},
